						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"session_id\": \"user_123\",\n    \"message\": \"Is Dr. Smith available tomorrow?\"\n}"
						},
						"url": {
							"raw": "http://localhost:8000/chat",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8000",
							"path": ["chat"]
						}
					}
				},
				{
					"name": "2. Book Appointment",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"session_id\": \"user_123\",\n    \"message\": \"Please book an appointment for me (John Doe) with Dr. Smith tomorrow at 10:30. My email is vr7797387@gmail.com\"\n}"
						},
						"url": {
							"raw": "http://localhost:8000/chat",
							"protocol": "http",
							"host": ["localhost"],
							"port": "8000",
							"path": ["chat"]
